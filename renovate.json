{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>tourbillon-health/renovate-config",
    "customManagers:helmChartYamlAppVersions"
  ],
  "addLabels": [
    "{{parentDir}}"
  ],
  "packageRules": [
    {
      "matchFileNames": [
        "**/Chart.yaml",
        "**/values.yaml"
      ],
      "pinDigests": false
    },
    {
      "matchFileNames": [
        "charts/**"
      ],
      "bumpVersions": [
        {
          "filePatterns": [
            "{{packageFileDir}}/Chart.yaml"
          ],
          "matchStrings": [
            "version:\\s(?<version>[^\\s]+)"
          ],
          "bumpType": "{{#if isPatch}}patch{{else}}minor{{/if}}"
        }
      ]
    }
  ]
}
